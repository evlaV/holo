diff --git a/src/platforms/wayland/windoweffects.cpp b/src/platforms/wayland/windoweffects.cpp
index aaecb2b9..c5a79db7 100644
--- a/src/platforms/wayland/windoweffects.cpp
+++ b/src/platforms/wayland/windoweffects.cpp
@@ -20,7 +20,7 @@
 #include "qwayland-contrast.h"
 #include "qwayland-slide.h"
 
-#include "surfacehelper.h"
+#include "helpers.h"
 
 #include <wayland-client-protocol.h>
 
@@ -61,7 +61,9 @@ public:
 
     ~Blur() override
     {
-        release();
+        if (isQpaAlive()) {
+            release();
+        }
     }
 };
 
@@ -85,7 +87,9 @@ public:
 
     ~Contrast() override
     {
-        release();
+        if (isQpaAlive()) {
+            release();
+        }
     }
 };
 
@@ -109,7 +113,9 @@ public:
 
     ~Slide() override
     {
-        release();
+        if (isQpaAlive()) {
+            release();
+        }
     }
 };
 
diff --git a/src/platforms/wayland/windowshadow.cpp b/src/platforms/wayland/windowshadow.cpp
index 3c2c2896..830dd0b5 100644
--- a/src/platforms/wayland/windowshadow.cpp
+++ b/src/platforms/wayland/windowshadow.cpp
@@ -6,9 +6,9 @@
 */
 
 #include "windowshadow.h"
+#include "helpers.h"
 #include "logging.h"
 #include "shm.h"
-#include "surfacehelper.h"
 
 #include <qwayland-shadow.h>
 
@@ -38,7 +38,7 @@ class ShadowManager : public QWaylandClientExtensionTemplate<ShadowManager>, pub
 public:
     ~ShadowManager()
     {
-        if (isActive()) {
+        if (isQpaAlive() && isActive()) {
             destroy();
         }
     }
@@ -53,9 +53,12 @@ class Shadow : public QtWayland::org_kde_kwin_shadow
 {
 public:
     using QtWayland::org_kde_kwin_shadow::org_kde_kwin_shadow;
+
     ~Shadow()
     {
-        destroy();
+        if (isQpaAlive()) {
+            destroy();
+        }
     }
 };
 
@@ -188,6 +191,10 @@ void WindowShadow::internalDestroy()
         return;
     }
 
+    if (!isQpaAlive()) {
+        return;
+    }
+
     // Only call surfaceForWindow and unset the surface if the native window is alive.
     // Otherwise window->create() might be called when the window is being destroyed, leading to a crash.
     if (window && window->nativeInterface<QNativeInterface::Private::QWaylandWindow>() && ShadowManager::instance()->isActive()) {
diff --git a/src/platforms/wayland/windowsystem.cpp b/src/platforms/wayland/windowsystem.cpp
index 014b5357..1c52b840 100644
--- a/src/platforms/wayland/windowsystem.cpp
+++ b/src/platforms/wayland/windowsystem.cpp
@@ -5,8 +5,8 @@
