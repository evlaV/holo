From ed458469188ee7f1f93947df5705f0a7c03221e2 Mon Sep 17 00:00:00 2001
From: Vignesh Raman <vignesh.raman@collabora.com>
Date: Wed, 4 Feb 2026 17:24:48 +0530
Subject: [PATCH 2/2] actions: overlay: test absolute path handling

This test verifies that absolute paths in overlay source are preserved
and not incorrectly joined with the recipe directory.

Signed-off-by: Vignesh Raman <vignesh.raman@collabora.com>
---
 tests/exit_test/exit_test.sh               | 1 +
 tests/exit_test/overlay-absolute-path.yaml | 7 +++++++
 tests/exit_test/overlay/overlay.txt        | 1 +
 3 files changed, 9 insertions(+)
 create mode 100644 tests/exit_test/overlay-absolute-path.yaml
 create mode 100644 tests/exit_test/overlay/overlay.txt

diff --git a/tests/exit_test/exit_test.sh b/tests/exit_test/exit_test.sh
index d8d3236..077c9ad 100755
--- a/tests/exit_test/exit_test.sh
+++ b/tests/exit_test/exit_test.sh
@@ -67,6 +67,7 @@ expect_success debos good.yaml
 expect_failure debos bad.yaml
 expect_failure debos pre-machine-failure.yaml
 expect_failure debos post-machine-failure.yaml
+expect_success debos overlay-absolute-path.yaml
 expect_failure debos overlay-missing-destination.yaml
 expect_failure debos overlay-missing-source.yaml
 expect_failure debos overlay-no-source.yaml
diff --git a/tests/exit_test/overlay-absolute-path.yaml b/tests/exit_test/overlay-absolute-path.yaml
new file mode 100644
index 0000000..f9e0f1c
--- /dev/null
+++ b/tests/exit_test/overlay-absolute-path.yaml
@@ -0,0 +1,7 @@
+architecture: amd64
+
+actions:
+  - action: overlay
+    description: Overlay from absolute path
+    source: /recipes/overlay
+    destination: /
diff --git a/tests/exit_test/overlay/overlay.txt b/tests/exit_test/overlay/overlay.txt
new file mode 100644
index 0000000..08047cf
--- /dev/null
+++ b/tests/exit_test/overlay/overlay.txt
@@ -0,0 +1 @@
+overlay
-- 
2.47.3

