                     $(srcdir)/script-lib-math.script                          \
                     $(srcdir)/script-lib-string.c                             \
                     $(srcdir)/script-lib-string.h                             \
-                    $(srcdir)/script-lib-string.script
+                    $(srcdir)/script-lib-string.script                        \
+                    $(srcdir)/script-lib-sys.c                                \
+                    $(srcdir)/script-lib-sys.h
 
