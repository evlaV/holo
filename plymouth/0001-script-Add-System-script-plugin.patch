 src/plugins/splash/script/plugin.c         |   3 +
 src/plugins/splash/script/script-lib-sys.c | 117 +++++++++++++++++++++
 src/plugins/splash/script/script-lib-sys.h |  37 +++++++
 4 files changed, 160 insertions(+), 1 deletion(-)
 create mode 100644 src/plugins/splash/script/script-lib-sys.c
 create mode 100644 src/plugins/splash/script/script-lib-sys.h

